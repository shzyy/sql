CREATE VIEW firma_praktikate_arv AS
SELECT f.firmanimi, COUNT(p.praktikabaasID) AS praktikate_arv
FROM firma f
LEFT JOIN praktikabaas p ON p.firmaID = f.firmaID
GROUP BY f.firmanimi;


CREATE VIEW sygisel_sundinud_juhendajad AS
SELECT eesnimi, perekonnanimi, synniaeg, telefon, palk
FROM praktikajuhendaja
WHERE MONTH(synniaeg) IN (9, 10, 11);

