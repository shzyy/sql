CREATE PROCEDURE lisa_uus_firma
    @firmanimi VARCHAR(50),
    @aadress VARCHAR(50),
    @telefon VARCHAR(20)
AS
BEGIN
    INSERT INTO firma (firmanimi, aadress, telefon)
    VALUES (@firmanimi, @aadress, @telefon);
END;

