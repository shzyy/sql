CREATE DATABASE Keys
USE Keys

CREATE TABLE PK(
students_id int PRIMARY KEY identity (1,1),
student_name varchar (30),
student_lastname varchar (30)
);
INSERT INTO PK(student_name, student_lastname)
VALUES ('Peter', 'Griffin'),
('Daniel', 'Rockstar'),
('Heron', 'Water'),
('Dmitri', 'Saar');

SELECT * from PK

CREATE TABLE FK(
course_id int PRIMARY KEY identity(1,1),
course_name varchar(50),
student_id int,
FOREIGN KEY (student_id) REFERENCES PK(students_id)
);
INSERT INTO FK(course_name, student_id)
VALUES
('Mathematics', 1),
('Programming', 2),
('Physics', 3),
('Biology', 4);

SELECT * from FK

